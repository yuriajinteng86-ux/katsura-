})

GrabTab:AddSection({ Name = "グラブ機能" })

_G.GrabSpamEnabled = false
_G.GrabSpamCount = 100

local ContextActionService = game:GetService("ContextActionService")

local function fireGrabButton(state)
    -- ContextActionServiceに登録されているグラブアクションを呼び出す
    local actions = ContextActionService:GetAllBoundActionInfo()
    for name, info in pairs(actions) do
        local lower = name:lower()
        if lower:find("grab") or lower:find("pick") or lower:find("hold") or lower:find("carry") then
            pcall(function()
                ContextActionService:CallFunction(name, state, nil)
            end)
        end
    end
end

GrabTab:AddSlider({
    Name = "連打回数",
    Min = 1,
    Max = 10000,
    Default = 100,
    Color = Color3.fromRGB(255, 255, 255),
    Increment = 1,
    ValueName = "回",
    Callback = function(Value)
        _G.GrabSpamCount = Value
    end
})

GrabTab:AddToggle({
    Name = "グラブ連打",
    Default = false,
    Callback = function(Value)
        _G.GrabSpamEnabled = Value
        if Value then
            -- 連打中は隠しアンチラグを自動起動（UIに表示しない）
            _G.HiddenAntiLag = true
            task.spawn(function()
                local plr = Players.LocalPlayer
                local SpawnRemote = ReplicatedStorage:WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction")
                while _G.HiddenAntiLag do
                    local char = plr.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if not hrp then RunService.Heartbeat:Wait() continue end
                    local toysFolder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
                    if not toysFolder then task.wait(0.1) continue end
                    local toy = toysFolder:FindFirstChild(SelectedToy)
                    if not toy then
                        pcall(function()
                            SpawnRemote:InvokeServer(SelectedToy, hrp.CFrame * CFrame.new(0, 5, 0), Vector3.zero)
                        end)
                        local t0 = tick()
                        repeat
                            RunService.Heartbeat:Wait()
                            toysFolder = Workspace:FindFirstChild(plr.Name .. "SpawnedInToys")
                            toy = toysFolder and toysFolder:FindFirstChild(SelectedToy)
                        until toy or tick() - t0 > 1 or not _G.HiddenAntiLag
                    end
                    if toy and toy.Parent then
                        local holdPart = toy:FindFirstChild("HoldPart")
                        if holdPart then
                            local holdingPlayer = holdPart:FindFirstChild("HoldingPlayer")
                            holdingPlayer = holdingPlayer and holdingPlayer.Value
                            if holdingPlayer and holdingPlayer ~= plr then
                                pcall(function()
                                    holdPart.DropItemRemoteFunction:InvokeServer(toy, hrp.CFrame * CFrame.new(0, 2000, 0), Vector3.zero)
                                end)
                                toy:Destroy()
                            else
                                pcall(function() holdPart.HoldItemRemoteFunction:InvokeServer(toy, char) end)
                                task.wait(0.05)
                                pcall(function()
                                    holdPart.DropItemRemoteFunction:InvokeServer(toy, hrp.CFrame * CFrame.new(0, 2000, 0), Vector3.zero)
                                end)
                                task.wait(0.01)
                            end
                        end
                    end
                    RunService.Heartbeat:Wait()
                end
            end)
            task.spawn(function()
                while _G.GrabSpamEnabled do
                    -- グラブボタンをループ連打
                    for i = 1, _G.GrabSpamCount do
                        if not _G.GrabSpamEnabled then break end
                        fireGrabButton(Enum.UserInputState.Begin)
                        fireGrabButton(Enum.UserInputState.End)
                    end
                    RunService.Heartbeat:Wait()
                end
                fireGrabButton(Enum.UserInputState.End)
            end)
        else
            -- 連打停止時は隠しアンチラグも停止
            _G.HiddenAntiLag = false
            fireGrabButton(Enum.UserInputState.End)
        end
    end
})

